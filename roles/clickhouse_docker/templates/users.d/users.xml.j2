<clickhouse>
  <users>
    <default>
      <no_password remove="remove"/>
      <password>{{ CLICKHOUSE_DEFAULT_USER_PASSWORD }}</password>

      <access_management>1</access_management>
      <named_collection_control>1</named_collection_control>
      <show_named_collections>1</show_named_collections>
      <show_named_collections_secrets>1</show_named_collections_secrets>

      <profile>default</profile>
      <quota>default</quota>
      <networks>
        <ip>::/0</ip>
      </networks>
    </default>

    <{{ CLICKHOUSE_ADMIN_USER }}>
      <password>{{ CLICKHOUSE_ADMIN_PASSWORD }}</password>
      <access_management>1</access_management>
      <named_collection_control>1</named_collection_control>
      <show_named_collections>1</show_named_collections>
      <show_named_collections_secrets>1</show_named_collections_secrets>
      <profile>default</profile>
      <quota>default</quota>
      <networks>
{% for net in CLICKHOUSE_ADMIN_ALLOWED_NETWORKS %}
        <ip>{{ net }}</ip>
{% endfor %}
      </networks>
    </{{ CLICKHOUSE_ADMIN_USER }}>

{% if CLICKHOUSE_READONLY_USER_ENABLED %}
    <{{ CLICKHOUSE_READONLY_USER }}>
      <password>{{ CLICKHOUSE_READONLY_PASSWORD }}</password>
      <profile>readonly</profile>
      <quota>default</quota>
      <networks>
{% for net in CLICKHOUSE_READONLY_ALLOWED_NETWORKS %}
        <ip>{{ net }}</ip>
{% endfor %}
      </networks>
    </{{ CLICKHOUSE_READONLY_USER }}>
{% endif %}
  </users>
</clickhouse>
